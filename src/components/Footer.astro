---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-top">
		<div class="footer-brand">
			<h2>Mutare Fence and Gates</h2>
			<p>Durable perimeter systems, high-quality wire products, and professional local service from Mutare.</p>
		</div>
		<div class="footer-columns">
			<div>
				<h3>Company</h3>
				<ul>
					<li><a href="/">Home</a></li>
					<li><a href="/about">About</a></li>
					<li><a href="#services">Products</a></li>
					<li><a href="#contact">Contact</a></li>
				</ul>
			</div>
			<div>
				<h3>Contact</h3>
				<address>
					06 Bvumba Road<br />
					Mutare, Zimbabwe
				</address>
				<p><a href="mailto:info@mutarefence.co.zw">info@mutarefence.co.zw</a></p>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Mutare Fence and Gates. All rights reserved.</p>
	</div>
</footer>
<style>
	.site-footer {
		padding: 3rem 1.5rem 2rem;
		background: linear-gradient(180deg, rgba(35, 55, 255, 0.06), transparent 80%);
		color: rgb(var(--gray-dark));
	}

	.footer-top {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 2rem;
		max-width: 1200px;
		margin: 0 auto;
		padding-bottom: 2rem;
		border-bottom: 1px solid rgba(35, 55, 255, 0.12);
	}

	.footer-brand h2 {
		margin-bottom: 0.75rem;
	}

	.footer-brand p {
		max-width: 420px;
		line-height: 1.8;
	}

	.footer-columns {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
	}

	.footer-columns h3 {
		margin-bottom: 1rem;
	}

	.footer-columns ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-columns li {
		margin-bottom: 0.75rem;
	}

	.footer-columns a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}

	.footer-columns a:hover {
		color: var(--accent);
	}

	.footer-bottom {
		text-align: center;
		padding-top: 1.5rem;
		font-size: 0.95rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 820px) {
		.footer-top,
		.footer-columns {
			grid-template-columns: 1fr;
		}
	}
</style>
