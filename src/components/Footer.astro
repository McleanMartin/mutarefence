---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-top">
			<div class="footer-brand">
				<p class="footer-eyebrow">Mutare, Zimbabwe</p>
				<h2>Mutare Fence and Gates</h2>
				<p class="footer-lede">
					Durable perimeter systems, high-quality wire products, and professional local service.
				</p>
			</div>
			<div class="footer-columns">
				<div class="footer-col">
					<h3>Explore</h3>
					<ul>
						<li><a href="/">Home</a></li>
						<li><a href="/about">About</a></li>
						<li><a href="/#services">Products</a></li>
						<li><a href="/#contact">Contact</a></li>
					</ul>
				</div>
				<div class="footer-col footer-col-contact">
					<h3>Contact</h3>
					<address>
						06 Bvumba Road<br />
						Mutare, Zimbabwe
					</address>
					<p class="footer-email">
						<a href="mailto:info@mutarefence.co.zw">info@mutarefence.co.zw</a>
					</p>
				</div>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Mutare Fence and Gates. All rights reserved.</p>
	</div>
</footer>
<style>
	.site-footer {
		margin-top: auto;
		color: rgb(var(--gray-dark));
	}

	.footer-inner {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: 3rem 1.5rem 2rem;
	}

	.footer-top {
		display: grid;
		grid-template-columns: 1.15fr 1fr;
		gap: 2.5rem 3rem;
		padding: 2rem 2.25rem;
		background: var(--surface);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-md);
	}

	.footer-eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--accent);
	}

	.footer-brand h2 {
		margin: 0 0 0.75rem;
		font-size: 1.5rem;
		letter-spacing: -0.03em;
	}

	.footer-lede {
		margin: 0;
		max-width: 28rem;
		line-height: 1.65;
		color: rgb(var(--gray));
		font-size: 0.98rem;
	}

	.footer-columns {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem 2rem;
	}

	.footer-col h3 {
		margin: 0 0 1rem;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgb(var(--gray));
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-col li {
		margin-bottom: 0.55rem;
	}

	.footer-col a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: color 0.15s ease;
	}

	.footer-col a:hover {
		color: var(--accent);
	}

	.footer-col address {
		font-style: normal;
		line-height: 1.65;
		font-size: 0.95rem;
		color: rgb(var(--gray-dark));
		margin: 0 0 0.75rem;
	}

	.footer-email {
		margin: 0;
	}

	.footer-email a {
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
	}

	.footer-email a:hover {
		color: var(--accent-dark);
		text-decoration: underline;
	}

	.footer-bottom {
		margin-top: 0;
		padding: 1.25rem 1.5rem;
		text-align: center;
		font-size: 0.88rem;
		color: rgba(255, 255, 255, 0.72);
		background: linear-gradient(180deg, rgb(28, 32, 48) 0%, rgb(15, 18, 28) 100%);
		border-top: 1px solid rgba(255, 255, 255, 0.06);
	}

	.footer-bottom p {
		margin: 0;
		max-width: var(--content-max);
		margin-inline: auto;
	}

	@media (max-width: 820px) {
		.footer-top {
			grid-template-columns: 1fr;
			padding: 1.5rem 1.25rem;
		}

		.footer-columns {
			grid-template-columns: 1fr;
		}
	}
</style>
