---
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<div class="brand">
		<a href="/" class="brand-link">
			<span class="brand-mark">MFG</span>
			<span>
				<strong>Mutare Fence & Gates</strong>
				<small>Trusted local fencing partner</small>
			</span>
		</a>
	</div>
	<nav class="site-nav">
		<HeaderLink href="/">Home</HeaderLink>
		<HeaderLink href="/about">About</HeaderLink>
		<HeaderLink href="#services">Products</HeaderLink>
		<HeaderLink href="#contact">Contact</HeaderLink>
	</nav>
	<a class="button button-primary" href="#contact">Request a Quote</a>
</header>
<style>
	.site-header {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 1.25rem 1.5rem;
		background: white;
		box-shadow: 0 24px 60px rgba(34, 41, 57, 0.08);
		position: sticky;
		top: 0;
		z-index: 10;
	}

	.brand-link {
		display: inline-flex;
		align-items: flex-start;
		gap: 0.85rem;
		text-decoration: none;
		color: rgb(var(--black));
	}

	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 14px;
		background: rgba(35, 55, 255, 0.12);
		font-weight: 700;
		color: rgb(var(--accent-dark));
		font-size: 1rem;
	}

	.brand-link strong {
		display: block;
		font-size: 1rem;
	}

	.brand-link small {
		display: block;
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}

	.site-nav {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		justify-content: center;
	}

	.site-nav a {
		font-weight: 600;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.site-nav a.active,
	.site-nav a:hover {
		color: var(--accent);
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.95rem 1.8rem;
		border-radius: 999px;
		font-weight: 700;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button-primary {
		background: var(--accent);
		color: white;
		box-shadow: 0 18px 50px rgba(35, 55, 255, 0.18);
	}

	@media (max-width: 840px) {
		.site-header {
			grid-template-columns: 1fr;
			row-gap: 1rem;
		}
		.site-nav {
			justify-content: space-between;
			flex-wrap: wrap;
			gap: 1rem;
		}
		.button {
			width: 100%;
			justify-content: center;
		}
	}
</style>
