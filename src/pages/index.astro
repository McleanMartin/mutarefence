---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image="/blog.jpeg" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">MFG</p>
					<h1>Mutare&rsquo;s trusted perimeter security partner</h1>
					<p class="hero-text">Mutare Fence and Gates is your local supplier for premium wire products, fencing systems and gate solutions. We support residential, agricultural and commercial customers with practical security solutions and dependable local service.</p>
					<div class="hero-actions">
						<a class="button button-primary" href="#contact">Request a quote</a>
						<a class="button button-secondary" href="/about">Learn more</a>
					</div>
					<div class="hero-details">
						<div>
							<strong>Mission</strong>
							<p>To be a committed premier customer wire supplier of choice.</p>
						</div>
						<div>
							<strong>Vision</strong>
							<p>To be the local leader in supplying wire products.</p>
						</div>
					</div>
					<div class="hero-summary">
						<div>
							<strong>Address</strong>
							<p>06 Bvumba Road, Mutare</p>
						</div>
						<div>
							<strong>Local support</strong>
							<p>Expert advice and fast response from our Mutare team.</p>
						</div>
					</div>
				</div>
				<div class="hero-image">
					<img src="/blog.jpeg" alt="Mutare Fence and Gates team photo" />
				</div>
			</section>

			<section class="section section-overview">
				<div class="section-copy">
					<h2>Professional fencing solutions for every property</h2>
					<p>Mutare Fence and Gates combines local knowledge with a strong product range to protect homes, farms and businesses. Our team helps customers choose the best fencing and wire solution for the site, budget and security requirements.</p>
				</div>
				<div class="section-highlights">
					<div class="feature-card">
						<strong>Local expertise</strong>
						<p>We understand the unique needs of Mutare properties and provide practical fencing guidance.</p>
					</div>
					<div class="feature-card">
						<strong>Quality materials</strong>
						<p>We supply durable wire, fencing panels and gates selected for strength and long service life.</p>
					</div>
					<div class="feature-card">
						<strong>Customer service</strong>
						<p>From quote to delivery, we maintain clear communication and a premium customer experience.</p>
					</div>
				</div>
			</section>

			<section id="services" class="section section-services">
				<h2>Our products</h2>
				<div class="service-grid">
					<div class="service-card">
						<h3>Diamond fencing</h3>
						<p>Reliable perimeter fencing suitable for residential and commercial boundaries.</p>
					</div>
					<div class="service-card">
						<h3>Clear view fencing</h3>
						<p>Secure, modern fencing with high visibility for open site protection.</p>
					</div>
					<div class="service-card">
						<h3>Barbed wire</h3>
						<p>Cost-effective deterrent wire for farms, warehouses and property lines.</p>
					</div>
					<div class="service-card">
						<h3>Razor wire</h3>
						<p>High-security coils designed to strengthen perimeter barriers.</p>
					</div>
					<div class="service-card">
						<h3>Gates</h3>
						<p>Custom gate solutions for driveways, entrances and industrial access points.</p>
					</div>
					<div class="service-card">
						<h3>Electric fencing</h3>
						<p>Effective electric systems for security and livestock containment.</p>
					</div>
					<div class="service-card">
						<h3>Palisade</h3>
						<p>Heavy-duty steel profiling for high-security perimeter protection.</p>
					</div>
				</div>
			</section>

			<section class="section section-difference">
				<h2>Why customers choose us</h2>
				<ul class="feature-list">
					<li>Trusted local supplier with strong community experience.</li>
					<li>Wide product range for security, agricultural and commercial needs.</li>
					<li>Personalized recommendations based on real site conditions.</li>
					<li>Clear pricing, fast responses and reliable local support.</li>
					<li>Professional quality across materials, delivery and guidance.</li>
				</ul>
			</section>

			<section id="contact" class="section section-contact">
				<div class="contact-panel">
					<h2>Ready to secure your property?</h2>
					<p>Contact Mutare Fence and Gates for a personalized quote, product advice or a site consultation. We are ready to support homes, farms and businesses with dependable fencing solutions.</p>
					<div class="contact-details">
						<div>
							<strong>Address</strong>
							<p>06 Bvumba Road, Mutare</p>
						</div>
						<div>
							<strong>Email</strong>
							<p><a href="mailto:info@mutarefence.co.zw">info@mutarefence.co.zw</a></p>
						</div>
					</div>
					<a class="button button-primary" href="mailto:info@mutarefence.co.zw">Email us</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: var(--content-max);
		margin: 0 auto;
		padding: 1.5rem 1.25rem 3rem;
	}

	.hero {
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		gap: clamp(1.5rem, 3vw, 3rem);
		align-items: stretch;
		padding: clamp(2rem, 4vw, 3.25rem) clamp(1.25rem, 3vw, 2.75rem);
		background: var(--surface);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-xl);
		margin: 0 0 1.5rem;
		box-shadow: var(--shadow-lg);
		overflow: hidden;
	}

	.hero-copy {
		max-width: 36rem;
		align-self: center;
		padding-block: 0.25rem;
	}

	.eyebrow {
		display: inline-block;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		font-weight: 700;
		font-size: 0.72rem;
		color: var(--accent);
		margin-bottom: 1rem;
		padding: 0.35rem 0.65rem;
		background: var(--accent-softer);
		border: 1px solid var(--border-accent);
		border-radius: 999px;
	}

	.hero h1 {
		font-size: clamp(2.15rem, 4.2vw, 3.35rem);
		margin: 0;
		line-height: 1.08;
		letter-spacing: -0.035em;
	}

	.hero-text {
		margin: 1.25rem 0 0;
		font-size: 1.05rem;
		line-height: 1.7;
		max-width: 38rem;
		color: rgb(var(--gray));
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 1.75rem 0 2rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.5rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.95rem;
		text-decoration: none;
		transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button-primary {
		background: linear-gradient(180deg, #3a4dff 0%, var(--accent) 100%);
		color: #fff;
		box-shadow:
			0 1px 0 rgba(255, 255, 255, 0.2) inset,
			0 6px 20px rgba(var(--accent-rgb), 0.32);
	}

	.button-primary:hover {
		color: #fff;
	}

	.button-secondary {
		background: var(--surface);
		color: var(--accent-dark);
		border: 1px solid var(--border-accent);
		box-shadow: var(--shadow-sm);
	}

	.button-secondary:hover {
		background: var(--accent-softer);
		border-color: rgba(var(--accent-rgb), 0.28);
		color: var(--accent-dark);
	}

	.hero-details {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		margin-top: 0.25rem;
	}

	.hero-details > div {
		padding: 1rem 1.1rem;
		background: var(--surface-muted);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-md);
	}

	.hero-details strong {
		display: block;
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent-dark);
		margin-bottom: 0.4rem;
	}

	.hero-details p {
		margin: 0;
		line-height: 1.55;
		font-size: 0.95rem;
		color: rgb(var(--gray-dark));
	}

	.hero-summary {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		margin-top: 0.75rem;
	}

	.hero-summary > div {
		padding: 1rem 1.1rem;
		background: var(--surface-muted);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-md);
	}

	.hero-summary strong {
		display: block;
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent-dark);
		margin-bottom: 0.4rem;
	}

	.hero-summary p {
		margin: 0;
		line-height: 1.55;
		font-size: 0.95rem;
		color: rgb(var(--gray-dark));
	}

	.hero-image {
		position: relative;
		border-radius: var(--radius-lg);
		min-height: 280px;
		box-shadow: var(--shadow-md);
		border: 1px solid var(--border-subtle);
	}

	.hero-image::after {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: linear-gradient(145deg, rgba(var(--accent-rgb), 0.12) 0%, transparent 45%, rgba(var(--black), 0.15) 100%);
		pointer-events: none;
	}

	.hero-image img {
		width: 100%;
		height: 100%;
		min-height: 280px;
		object-fit: cover;
		display: block;
		border-radius: inherit;
	}

	.section {
		padding: clamp(2rem, 4vw, 2.75rem) clamp(1.25rem, 3vw, 2.25rem);
	}

	.section-overview,
	.section-services,
	.section-difference,
	.section-contact {
		margin: 0 0 1.25rem;
		background: var(--surface);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-md);
	}

	.section-overview {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.5rem 2rem;
	}

	@media (min-width: 900px) {
		.section-overview {
			grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
			align-items: start;
		}
	}

	.section-copy {
		max-width: 40rem;
	}

	.section h2 {
		font-size: clamp(1.65rem, 2.5vw, 2.15rem);
		margin: 0 0 0.75rem;
		letter-spacing: -0.03em;
	}

	.section-copy p {
		margin: 0;
		line-height: 1.7;
		color: rgb(var(--gray));
		font-size: 1.02rem;
	}

	.section-highlights {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 0.5rem;
	}

	.feature-card,
	.service-card {
		background: var(--surface-muted);
		padding: 1.35rem 1.4rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--border-subtle);
		transition: border-color 0.15s ease, box-shadow 0.15s ease;
	}

	.feature-card:hover,
	.service-card:hover {
		border-color: var(--border-accent);
		box-shadow: var(--shadow-sm);
	}

	.feature-card strong,
	.service-card h3 {
		display: block;
		margin-bottom: 0.5rem;
		font-size: 1.05rem;
		letter-spacing: -0.02em;
	}

	.feature-card p,
	.service-card p {
		margin: 0;
		line-height: 1.65;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.service-card h3 {
		font-size: 1.08rem;
		padding-top: 0.35rem;
		border-top: 2px solid var(--accent);
		margin-top: 0;
	}

	.section-services h2 {
		margin-bottom: 0.25rem;
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.feature-list {
		list-style: none;
		padding: 0;
		margin: 1.25rem 0 0;
		display: grid;
		gap: 0.65rem;
	}

	.feature-list li {
		padding: 0.85rem 1rem 0.85rem 2.65rem;
		position: relative;
		line-height: 1.55;
		background: var(--surface-muted);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-sm);
		font-size: 0.98rem;
	}

	.feature-list li::before {
		content: "";
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 3px var(--accent-soft);
	}

	.contact-panel {
		display: grid;
		gap: 1.25rem;
		padding: clamp(1.75rem, 3vw, 2.25rem);
		border-radius: var(--radius-md);
		background: linear-gradient(135deg, rgb(28, 34, 52) 0%, rgb(22, 28, 44) 50%, rgb(18, 22, 38) 100%);
		color: rgba(255, 255, 255, 0.88);
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow-lg);
	}

	.contact-panel h2 {
		color: #fff;
		margin: 0;
	}

	.contact-panel > p {
		margin: 0;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.75);
		font-size: 1.02rem;
		max-width: 42rem;
	}

	.contact-details {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.contact-details > div {
		padding: 1rem 1.15rem;
		background: rgba(255, 255, 255, 0.06);
		border-radius: var(--radius-sm);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.contact-details strong {
		display: block;
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(255, 255, 255, 0.55);
		margin-bottom: 0.35rem;
	}

	.contact-details p {
		margin: 0;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.92);
		font-size: 0.95rem;
	}

	.contact-details a {
		color: #a8b4ff;
		text-decoration: none;
		font-weight: 600;
	}

	.contact-details a:hover {
		color: #fff;
		text-decoration: underline;
	}

	.contact-panel .button-primary {
		justify-self: start;
		margin-top: 0.25rem;
	}

	@media (max-width: 1024px) {
		.service-grid,
		.section-highlights,
		.hero-details,
		.hero-summary,
		.contact-details {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 840px) {
		.hero {
			grid-template-columns: 1fr;
			padding: 1.75rem 1.25rem;
		}

		.hero-image {
			order: -1;
			min-height: 220px;
		}

		.hero-image img {
			min-height: 220px;
		}

		main {
			padding: 1rem 1rem 2.5rem;
		}
	}
</style>
